{% extends 'base.html.twig' %}

{% block title %}Citas index{% endblock %}

{% block body %}
    <h1>Citas index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Fecha_cita</th>
                <th>Hora_cita</th>
                <th>Estado</th>
                <th>Comentario</th>
                <th>Fecha_solicitud</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for cita in citas %}
            <tr>
                <td>{{ cita.id }}</td>
                <td>{{ cita.fechaCita ? cita.fechaCita|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ cita.horaCita ? cita.horaCita|date('H:i:s') : '' }}</td>
                <td>{{ cita.estado }}</td>
                <td>{{ cita.comentario }}</td>
                <td>{{ cita.fechaSolicitud ? cita.fechaSolicitud|date('Y-m-d H:i:s') : '' }}</td>
                <td>
                    <a href="{{ path('app_citas_show', {'id': cita.id}) }}">show</a>
                    <a href="{{ path('app_citas_edit', {'id': cita.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_citas_new') }}">Create new</a>
{% endblock %}
