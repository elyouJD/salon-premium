{% extends 'base.html.twig' %}

{% block title %}Facturas{% endblock %}

{% block body %}
    <h1>Facturas</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ factura.id }}</td>
            </tr>
            <tr>
                <th>Codigo_factura</th>
                <td>{{ factura.codigoFactura }}</td>
            </tr>
            <tr>
                <th>Fecha_factura</th>
                <td>{{ factura.fechaFactura ? factura.fechaFactura|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_facturas_index') }}">back to list</a>

    <a href="{{ path('app_facturas_edit', {'id': factura.id}) }}">edit</a>

    {{ include('facturas/_delete_form.html.twig') }}
{% endblock %}
