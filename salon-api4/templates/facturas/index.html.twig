{% extends 'base.html.twig' %}

{% block title %}Facturas index{% endblock %}

{% block body %}
    <h1>Facturas index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Codigo_factura</th>
                <th>Fecha_factura</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for factura in facturas %}
            <tr>
                <td>{{ factura.id }}</td>
                <td>{{ factura.codigoFactura }}</td>
                <td>{{ factura.fechaFactura ? factura.fechaFactura|date('Y-m-d H:i:s') : '' }}</td>
                <td>
                    <a href="{{ path('app_facturas_show', {'id': factura.id}) }}">show</a>
                    <a href="{{ path('app_facturas_edit', {'id': factura.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_facturas_new') }}">Create new</a>
{% endblock %}
